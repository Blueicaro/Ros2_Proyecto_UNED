<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

    <xacro:property name="base_radius" value="0.35" />
    <xacro:property name="base_length" value="0.1" />
    <xacro:property name="wheel_radius" value="0.1" />
    <xacro:property name="wheel_length" value="0.05" />
    <xacro:property name="wheel_offset" value="0.1" />
    <xacro:property name="lidar_radius" value="0.05" />
    <xacro:property name="lidar_length" value="0.06" />

    <link name="base_footprint" />
    <link name="base_link">
        <visual>
            <geometry>
                <cylinder radius="${base_radius}" length="${base_length}" />
            </geometry>
            <origin xyz="0.0 0.0 ${base_length/2.0}" rpy="0.0 0.0 0.0" />
            <material name="green">
            </material>
        </visual>
        <collision>
            <geometry>
                <cylinder radius="${base_radius}" length="${base_length}" />
            </geometry>
        </collision>
        <xacro:cylinder_inertia m="5.0" r="${base_radius}" l="${base_length}" o_xyz="0 0 2"
            o_rpy="0 0 0" />
    </link>

    <xacro:macro name="wheel_link" params="prefix">
        <link name="${prefix}_wheel_link">
            <visual>
                <geometry>
                    <cylinder radius="${wheel_radius}" length="${wheel_length}" />
                </geometry>
                <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0" />
                <material name="black" />
            </visual>
            <collision>
                <geometry>
                    <cylinder radius="${wheel_radius}" length="${wheel_length}" />
                </geometry>
                <origin xyz="0 0 0" rpy="0 0 0" />
            </collision>
            <xacro:cylinder_inertia m="1.0" r="${wheel_radius}" l="${wheel_length}" o_xyz="0 0 0"
                o_rpy="${pi /2.0} 0 0" />
        </link>
    </xacro:macro>

    <xacro:macro name="wheel_transmission" params="prefix">
        <!-- Transmisión de las ruedas-->
        <transmission name="${prefix}_wheel_trans">
            <type>transmission_interface/SimpleTransmission</type>
            <joint name="base_${prefix}_wheel_joint">
                <hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface>
            </joint>
            <actuator name="wheel_motor_${prefix}">
                <mechanicalReduction>5.0</mechanicalReduction>
                <hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface>
            </actuator>
        </transmission>

    </xacro:macro>

    <xacro:wheel_link prefix="left" />
    <xacro:wheel_link prefix="right" />
    <xacro:wheel_transmission prefix="left" />
    <xacro:wheel_transmission prefix="right" />


    <link name="lidar_link">
        <visual>
            <geometry>
                <cylinder radius="${lidar_radius}" length="${lidar_length}" />
            </geometry>
            <material name="white" />
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0" />
        </visual>
    </link>

    <link name="caster_ball_link">
        <visual>
            <geometry>
                <sphere radius="0.05" />
            </geometry>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <material name="gray">
            </material>
        </visual>
        <collision>
            <geometry>
                <sphere radius="${wheel_radius/2.0}" />
            </geometry>
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0" />
        </collision>
    </link>

    <joint name="base_joint" type="fixed">
        <parent link="base_footprint" />
        <child link="base_link" />
        <origin xyz="0.0 0.0 ${wheel_radius/2.0}" rpy="0.0 0.0 0.0" />

    </joint>


    <joint name="base_right_wheel_joint" type="continuous">
        <parent link="base_link" />
        <child link="right_wheel_link" />
        <origin xyz="${-wheel_offset} ${base_radius+(wheel_length/2.0)} 0.0" rpy="1.57 0.0 0.0" />
        <axis xyz="0.0 0.0 1.0" />
    </joint>

    <joint name="base_left_wheel_joint" type="continuous">
        <parent link="base_link" />
        <child link="left_wheel_link" />
        <origin xyz="${-wheel_offset} ${-(base_radius+(wheel_length/2.0))} 0.0" rpy="1.57 0.0 0.0" />
        <axis xyz="0.0 0.0 1.0" />
    </joint>


    <joint name="base_caster_ball_joint" type="fixed">
        <parent link="base_link" />
        <child link="caster_ball_link" />
        <origin xyz="${base_radius/1.5} 0.0 ${-wheel_radius/3.0}" rpy="0.0 0.0 0.0" />
    </joint>

    <joint name="base_lidar_joint" type="fixed">
        <parent link="base_link" />
        <child link="lidar_link" />
        <origin xyz="${-base_radius/1.5} 0.0 ${base_length+ lidar_length/2.0}" rpy="0.0 0.0 0.0" />
    </joint>

    <sensor name="lidar_sensor" type="ray">
        <parent link="lidar_link" />
        <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0" />
        <ray>
            <scan>
                <horizontal>
                    <samples>360</samples>
                    <resolution>1.0</resolution>
                    <min_angle>0.0</min_angle>
                    <max_angle>6.28319</max_angle>
                </horizontal>
            </scan>
            <range>
                <min>0.1</min>
                <max>1.0</max>
                <resolution>0.01</resolution>
            </range>
        </ray>
    </sensor>
</robot>