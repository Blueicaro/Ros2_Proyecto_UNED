<?xml version="1.0"?>
<robot name="mobile_base" xmlns:xacro="http://www.ros.org/wiki/xacro">
    <!-- Como el diseño esn milímetros, al cargar rzvix interpreta que son metros, así que hay  que
    escalarlo-->
    <xacro:property name="base_height" value="0.0096" />
    <xacro:property name="base_width" value="0.2" />
    <xacro:property name="wheel_radius" value="0.02" />
    <xacro:property name="wheel_length" value="0.015" />

    <link name="base_link">
        <visual>
            <geometry>
                <mesh filename="package://robot_description/meshes/roomba-body.stl"
                    scale="0.001 0.001 0.001" />
            </geometry>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <material name="white" />
        </visual>
        <collision>
            <geometry>
                <cylinder radius="${base_width/2}" length="${base_height}" />
            </geometry>
        </collision>
        <xacro:cylinder_inertial m="0.5" r="${base_width/2}" l="${base_height}" o_xyz="0 0 0"
            o_rpy="0 0 0" />
    </link>

    <link name="base_footprint" />

    <joint name="footprint_to_base" type="fixed">
        <parent link="base_footprint" />
        <child link="base_link" />
        <origin xyz="0 0 ${wheel_radius/2}" rpy="0 0 0" />
    </joint>


    <xacro:macro name="wheel_link" params="prefix">
        <link name="${prefix}_wheel_link">
            <visual>
                <geometry>
                    <mesh filename="package://robot_description/meshes/roomba-wheel.stl"
                        scale="0.001 0.001 0.001" />
                </geometry>
                <origin xyz="0 0 0" rpy="0 0 0" />
                <material name="black" />
            </visual>
            <collision>
                <geometry>
                    <cylinder radius="${wheel_radius}" length="${wheel_length}" />
                </geometry>
            </collision>
            <xacro:cylinder_inertial m="0.1" r="${wheel_radius}" l="${wheel_length}" o_xyz="0 0 0"
                o_rpy="0 0 0" />
        </link>
    </xacro:macro>

    <xacro:wheel_link prefix="left" />
    <xacro:wheel_link prefix="right" />

    <link name="caster_ball">
        <visual>
            <geometry>
                <mesh filename="package://robot_description/meshes/roomba-ballcaster.stl"
                    scale="0.001 0.001 0.001" />
            </geometry>
            <origin xyz="0 0 0" rpy="0 0 0" />
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry>
                <sphere radius="0.06" />
            </geometry>
            <xacro:sphere_inertial m="0.01" r="0.06" o_xyz="0 0 0" o_rpy="0 0 0" />
        </collision>
    </link>

    <link name="lidar">
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry>
                <mesh filename="package://robot_description/meshes/roomba-lidar.stl"
                    scale="0.001 0.001 0.001" />
            </geometry>
            <material name="red" />
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry>
                <cylinder radius="0.05" length="0.02" />
            </geometry>
            <xacro:cylinder_inertial m="0.05" r="0.05" l="0.02" o_xyz="0 0 0" o_rpy="0 0 0" />
        </collision>
    </link>

    <joint name="right_wheel_joint" type="continuous">
        <parent link="base_link" />
        <child link="right_wheel_link" />
        <origin xyz="-0.05 0.11 -${wheel_radius/2}" rpy="0 0 0" />
        <axis xyz="0 1 0" />
    </joint>

    <joint name="left_wheel_joint" type="continuous">
        <parent link="base_link" />
        <child link="left_wheel_link" />
        <origin xyz="-0.05 -0.11 -${wheel_radius/2}" rpy="0 0 0" />
        <axis xyz="0 1 0" />
    </joint>


    <joint name="caster_ball_joint" type="fixed">
        <parent link="base_link" />
        <child link="caster_ball" />
        <origin xyz="0.15 0 -${wheel_radius}" rpy="0 0 0" />
    </joint>

    <joint name="lidar_joint" type="continuous">
        <parent link="base_link" />
        <child link="lidar" />
        <origin xyz="-${base_width/2} 0 0.1" rpy="0 0 0" />
        <axis xyz="0 0 1" />

    </joint>


</robot>